{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Capture Hook Output",
  "description": "Schema for _evidence/hook-output/latest.json produced by pre-commit.governance.ps1",
  "type": "object",
  "required": ["timestamp", "hook_version", "stages", "git_context", "overall_result"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of hook execution"
    },
    "hook_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the governance hook script"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["name", "exit_code", "output_file", "duration_ms"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["manifest-regen", "sadp-audit", "ai-guard", "test-governance"]
          },
          "exit_code": {
            "type": "integer",
            "description": "Process exit code (0=pass, non-zero=block/error)"
          },
          "output_file": {
            "type": "string",
            "description": "Relative path to captured output file"
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0,
            "description": "Execution duration in milliseconds"
          }
        }
      }
    },
    "git_context": {
      "type": "object",
      "required": ["branch", "staged_file_count"],
      "properties": {
        "branch": {
          "type": "string",
          "description": "Current git branch name"
        },
        "commit_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of commits in repository"
        },
        "staged_file_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of files in staging area"
        }
      }
    },
    "overall_result": {
      "type": "string",
      "enum": ["PASS", "BLOCKED"],
      "description": "Final gate decision"
    }
  }
}
