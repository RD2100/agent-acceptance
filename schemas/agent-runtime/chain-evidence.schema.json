{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChainEvidence",
  "description": "Role/session chain for an @go run.",
  "type": "object",
  "required": ["run_id", "task_file", "executor_id", "created_at", "producer"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "task_file": { "type": "string", "minLength": 1 },
    "executor_id": { "type": "string", "minLength": 1 },
    "reviewer_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" }
  },
  "additionalProperties": false
}
