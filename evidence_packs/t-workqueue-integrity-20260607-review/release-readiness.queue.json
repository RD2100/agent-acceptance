{
  "queue_id": "release-readiness-queue",
  "owner": "code-agent",
  "mode": "safe-batch",
  "description": "Release-readiness queue. Currently reuses the shared active batch-local-quality checks until a dedicated active release batch is restored.",
  "items": [
    {
      "id": "q-release-readiness",
      "title": "Release readiness via shared local-quality batch (10 checks)",
      "tier": 0,
      "task_file": "scripts/examples/batch-local-quality.json",
      "runner": "scripts/Run-Batch.ps1",
      "status": "pending",
      "allowed_files": ["runs/powershell-acceptance/**"],
      "forbidden_files": ["src/**", "configs/**", "tasks.yaml", "projects.yaml"],
      "expected_artifacts": ["runs/powershell-acceptance/batch-local-quality/batch-report.md"],
      "escalate_on": ["failed", "missing_artifact", "timeout", "forbidden_command"]
    }
  ]
}
