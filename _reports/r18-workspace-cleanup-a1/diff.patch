+    + r5.stdout)
+
+# staging-count-reconciliation.md
+recon = [
+    "# Staging Count Reconciliation",
+    "",
+    "## Discrepancy Explanation",
+    "",
+    "| Source | Count | Explanation |",
+    "|--------|-------|-------------|",
