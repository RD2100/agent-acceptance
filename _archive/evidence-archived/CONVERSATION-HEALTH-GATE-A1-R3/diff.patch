+        for val in required:
+            assert val in policy_enum, f"policy enum missing code output value: {val}"
+
+
+# ---------------------------------------------------------------------------
+# Threshold logic tests (check_handoff_needed.py v2)
+# ---------------------------------------------------------------------------
+
+class TestCheckHandoffNeeded:
